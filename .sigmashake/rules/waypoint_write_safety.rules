# waypoint_write_safety.rules
# Technology: waypoint | Capability: write

rule waypoint-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_waypoint_PATTERN"
  MESSAGE "Blocked an unsafe pattern in waypoint. Use the recommended best practices for 2025/2026."
}

rule waypoint-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_waypoint_API"
  MESSAGE "You are using an outdated API for waypoint. Please upgrade to the newer API."
}
